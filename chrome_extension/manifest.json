{
  "manifest_version": 3,
  "name": "Stream Monitor Tab Closer",
  "version": "1.4.0",
  "description": "Automatically closes Twitch tabs when the streamer raids someone else. Works with Stream Monitor.",

  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "48": "icon-48.png",
      "96": "icon-96.png"
    },
    "default_title": "Stream Monitor Tab Closer",
    "default_popup": "popup.html"
  },

  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
