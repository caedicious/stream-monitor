{
  "manifest_version": 3,
  "name": "Stream Monitor Companion",
  "version": "1.5.4",
  "description": "Automatically closes Twitch tabs when the streamer raids someone else. Works with Stream Monitor.",

  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],

  "optional_permissions": [
    "notifications"
  ],

  "host_permissions": [
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "96": "icon-96.png",
      "128": "icon-128.png"
    },
    "default_title": "Stream Monitor Companion",
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
